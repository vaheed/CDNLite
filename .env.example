# CDNLite environment template
# Copy this file to .env and replace all example secrets before production use.

# Image owner used by Compose image tags.
# Production sample: set this to your GitHub/GHCR organization or registry owner.
GITHUB_REPOSITORY_OWNER=local

# PostgreSQL database name created by the postgres container on first boot.
# Production sample: use a stable application database name such as cdnlite.
POSTGRES_DB=cdnlite

# PostgreSQL bootstrap user created by the postgres container on first boot.
# Production sample: use a dedicated database user, not a shared admin account.
POSTGRES_USER=cdnlite

# PostgreSQL bootstrap password.
# Production sample: replace with a long random secret from your secret manager.
POSTGRES_PASSWORD=cdnlite

# Hostname used by core to reach PostgreSQL from inside Compose.
# Production sample: postgres for Compose, or your managed database private DNS name.
DB_HOST=postgres

# PostgreSQL port used by core.
# Production sample: 5432 unless your database service exposes a custom port.
DB_PORT=5432

# Database name used by core.
# Production sample: match POSTGRES_DB or your managed database name.
DB_DATABASE=cdnlite

# Database user used by core.
# Production sample: match POSTGRES_USER or a least-privilege application user.
DB_USERNAME=cdnlite

# Database password used by core.
# Production sample: replace with the application database user's secret.
DB_PASSWORD=cdnlite

# Enables structured application logs from core.
# Production sample: keep enabled.
APP_LOG_ENABLED=1

# Minimum log level for core logs.
# Production sample: info for normal operation, debug only during temporary troubleshooting.
APP_LOG_LEVEL=info

# Enables verbose debug behavior.
# Production sample: always 0.
APP_DEBUG=0

# Stable edge node identifier used by core and the edge agent.
# Production sample: a unique ID such as edge-us-east-1-a.
EDGE_ID=edge-local-1

# Shared edge auth token used to sign edge-agent requests.
# Production sample: replace with a long random token provisioned with cdn:edge:register-token.
EDGE_TOKEN=edge-dev-token

# Hostname reported by the edge agent during registration and heartbeat.
# Production sample: the edge server hostname, such as edge-us-east-1-a.example.net.
EDGE_HOSTNAME=edge-local-1

# Public IPv4 reported by the edge agent; auto detects it at runtime.
# Production sample: auto, or a fixed public IPv4 if detection is not allowed.
EDGE_PUBLIC_IP=auto

# Region slug used for edge metadata and DNS policy.
# Production sample: a stable region code such as us-east-1, eu-west-1, or ir.
EDGE_REGION=local

# Edge software/version label reported by the agent.
# Production sample: your deployed image or release version, such as v1.4.2.
EDGE_VERSION=v1

# Default NGINX proxy-cache TTL for cacheable 200, 301, and 302 responses.
# Production sample: choose a conservative default such as 60s, 5m, or 1h.
CDNLITE_CACHE_DEFAULT_TTL=60s
CDNLITE_SSL_SECRET_KEY=change-me-long-random-secret

# Runtime environment for readiness and security defaults.
# Production sample: production.
APP_ENV=local

# Optional control-plane bearer token. When set, non-edge /api/v1/* routes require Authorization: Bearer <token>.
# Production sample: set a long random token from your secret manager.
CDNLITE_API_TOKEN=

# Optional shared secret injected by edge to origin when a site has origin_shield_header_name + matching secret hash configured.
# Production sample: set a long random secret and lock origin to this header check.
CDNLITE_ORIGIN_SHIELD_SECRET=change-me-long-random-secret

# Host port exposing the core API container.
# Production sample: bind behind a reverse proxy or private network, not directly public.
CORE_HOST_PORT=8080

# Host port exposing the OpenResty edge container.
# Production sample: 80/443 via a load balancer or reverse proxy.
EDGE_HOST_PORT=8081

# Host port exposing PostgreSQL.
# Production sample: avoid exposing PostgreSQL publicly; prefer private networking.
POSTGRES_HOST_PORT=5432

# Core URL used by the edge agent from inside Compose.
# Production sample: an internal HTTPS URL or private service DNS name.
CORE_URL=http://core:8080

# Host directory mounted into edge and edge-agent for config and metrics.
# Production sample: use a persistent, restricted directory owned by the runtime user.
EDGE_CONFIG_DIR=./edge/config

# Config snapshot path inside the edge-agent and edge containers.
# Production sample: keep under /var/lib/cdnlite/config.json.
EDGE_CONFIG_PATH=/var/lib/cdnlite/config.json

# Metrics NDJSON path written by OpenResty and read by the edge agent.
# Production sample: keep under /var/lib/cdnlite/metrics.ndjson.
METRIC_PATH=/var/lib/cdnlite/metrics.ndjson

# Enables PowerDNS sync from core.
# Production sample: set to 1 only after POWERDNS_API_URL and POWERDNS_API_KEY are valid.
POWERDNS_ENABLED=0

# Makes DNS API/CLI operations fail when PowerDNS sync fails.
# Production sample: 1 when PowerDNS is required for correctness, 0 during migration/testing.
POWERDNS_STRICT=0

# PowerDNS API base URL used by core.
# Production sample: an internal HTTPS URL, such as https://pdns-api.internal:8443.
POWERDNS_API_URL=http://powerdns:8081

# PowerDNS API key sent as X-API-Key.
# Production sample: replace with a secret generated in the PowerDNS API configuration.
POWERDNS_API_KEY=change-me

# PowerDNS server ID path segment.
# Production sample: localhost unless your PowerDNS API uses a different server ID.
POWERDNS_SERVER_ID=localhost

# PowerDNS zone kind for created zones.
# Production sample: NATIVE for common single-primary setups; use MASTER/SLAVE only if configured.
POWERDNS_ZONE_KIND=NATIVE

# Nameservers written into managed customer zones.
# Production sample: public authoritative nameservers for your CDN platform.
POWERDNS_ZONE_NAMESERVERS=ns1.vaheed.net,ns2.vaheed.net

# Platform-owned base DNS zone for edge routing records.
# Production sample: a domain you control, such as cdn.example.com.
CDNLITE_EDGE_BASE_DOMAIN=vaheed.net

# Label prefix for generated edge hostnames under CDNLITE_EDGE_BASE_DOMAIN.
# Production sample: edge.
CDNLITE_EDGE_ZONE_PREFIX=edge

# Default target label for customer DNS policy records.
# Production sample: geo.
CDNLITE_EDGE_DEFAULT_TARGET=geo

# TTL in seconds for platform edge DNS records.
# Production sample: 60 for quick failover, higher for lower DNS query volume.
CDNLITE_EDGE_TTL=60

# Health mode used in generated PowerDNS records.
# Production sample: ifportup for TCP health, ifurlup for HTTP health, static to disable health checks.
CDNLITE_EDGE_HEALTH_MODE=ifportup

# TCP/HTTP port checked by PowerDNS health rules.
# Production sample: 80 or 443 depending on the edge listener.
CDNLITE_EDGE_HEALTH_PORT=80

# HTTP path checked when CDNLITE_EDGE_HEALTH_MODE=ifurlup.
# Production sample: /cdn-health.
CDNLITE_EDGE_HEALTH_URL=/cdn-health

# PowerDNS health-check timeout in seconds.
# Production sample: 1 or 2 for edge failover.
CDNLITE_EDGE_HEALTH_TIMEOUT=1

# PowerDNS health-check interval in seconds.
# Production sample: 10 for responsive failover.
CDNLITE_EDGE_HEALTH_INTERVAL=10

# Consecutive failures before an edge is considered unhealthy.
# Production sample: 2 or 3 to avoid flapping.
CDNLITE_EDGE_HEALTH_MIN_FAILURES=2

# PowerDNS selector for choosing healthy edge records.
# Production sample: pickclosest for geo-aware routing, random for simple balancing.
CDNLITE_EDGE_SELECTOR=pickclosest

# PowerDNS backup selector used when primary health checks fail.
# Production sample: empty unless you have a defined backup policy.
CDNLITE_EDGE_BACKUP_SELECTOR=empty

# Record type used for proxied apex records.
# Production sample: ALIAS when supported by your DNS stack.
CDNLITE_EDGE_APEX_MODE=ALIAS

# Default geo policy mode for generated records.
# Production sample: auto.
CDNLITE_GEO_DEFAULT_POLICY=auto

# Enables country-level geo rules.
# Production sample: true when you need country routing.
CDNLITE_GEO_ENABLE_COUNTRY_RULES=true

# Enables continent-level geo rules.
# Production sample: true for broad regional routing.
CDNLITE_GEO_ENABLE_CONTINENT_RULES=true

# Enables region-level geo rules.
# Production sample: true when region metadata is available.
CDNLITE_GEO_ENABLE_REGION_RULES=true

# Optional IPv4 address for ns1 in the platform DNS zone.
# Production sample: set to the public IPv4 of ns1, or leave empty if managed elsewhere.
CDNLITE_NS1_IP=

# Optional IPv4 address for ns2 in the platform DNS zone.
# Production sample: set to the public IPv4 of ns2, or leave empty if managed elsewhere.
CDNLITE_NS2_IP=

# Bootstraps platform edge DNS records during sync.
# Production sample: 1 for normal operation.
CDNLITE_BOOTSTRAP_EDGE_DNS=1

# CI/test-only: keep the edge-agent container alive without running its loop.
# Production sample: always 0.
EDGE_AGENT_IDLE=0

# CI/test-only: host URL used by e2e checks for the mock PowerDNS API.
# Production sample: leave unset unless running local e2e with the powerdns profile.
POWERDNS_PUBLIC_API_URL=http://localhost:8089

# CI/test-only: host port that exposes the mock PowerDNS service.
# Production sample: leave unset unless running local e2e with the powerdns profile.
POWERDNS_HOST_PORT=8089

# CI/test-only: port listened on by the mock PowerDNS server inside the container.
# Production sample: leave unset unless running local e2e with the powerdns profile.
PDNS_PORT=8081
