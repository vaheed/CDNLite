# CDNLite local development environment template.
# Copy this file to .env for local Docker Compose:
#   cp .env.example .env
#
# Production operators should start from .env.production.example instead.
# Dashboard-only builds can use dash/.env.example.

GITHUB_REPOSITORY_OWNER=local

# Local PostgreSQL.
POSTGRES_DB=cdnlite
POSTGRES_USER=cdnlite
POSTGRES_PASSWORD=cdnlite
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=cdnlite
DB_USERNAME=cdnlite
DB_PASSWORD=cdnlite

# Core runtime.
APP_ENV=local
APP_LOG_ENABLED=1
APP_LOG_LEVEL=info
APP_DEBUG=0
CDNLITE_API_TOKEN=
CDNLITE_SSL_SECRET_KEY=change-me-long-random-secret
CDNLITE_ORIGIN_SHIELD_SECRET=change-me-long-random-secret

# Default local dashboard admin.
# These credentials are for local quickstart only.
CDNLITE_ADMIN_SESSION_TTL_SECONDS=28800
CDNLITE_CORS_ALLOWED_ORIGINS=http://localhost:8082,http://127.0.0.1:8082
CDNLITE_BOOTSTRAP_ADMIN_USER=1
CDNLITE_BOOTSTRAP_ADMIN_USERNAME=admin
CDNLITE_BOOTSTRAP_ADMIN_PASSWORD=admin
CDNLITE_BOOTSTRAP_ADMIN_DISPLAY_NAME="Local Admin"

# Local edge identity and bootstrap token.
EDGE_ID=edge-local-1
EDGE_TOKEN=edge-dev-token
CDNLITE_BOOTSTRAP_EDGE_TOKEN=1
CDNLITE_BOOTSTRAP_EDGE_ID=
CDNLITE_BOOTSTRAP_EDGE_TOKEN_VALUE=
EDGE_HOSTNAME=edge-local-1
EDGE_PUBLIC_IP=auto
EDGE_REGION=local
EDGE_VERSION=v1

# Local ports.
CORE_HOST_PORT=8080
EDGE_HOST_PORT=8081
EDGE_TLS_HOST_PORT=8443
POSTGRES_HOST_PORT=5432
DASHBOARD_PORT=8082

# Dashboard build defaults for the local Compose dashboard service.
VITE_CDNLITE_CORE_URL=http://localhost:8080
VITE_CDNLITE_EDGE_URL=http://localhost:8081
VITE_CDNLITE_APP_NAME=CDNLite Admin
VITE_CDNLITE_API_TOKEN=
VITE_ENABLE_EDGE_DEV_TOOLS=false
VITE_ENABLE_USAGE_SIMULATOR=false
VITE_ENABLE_SSL_TOOLS=true
VITE_ENABLE_SECURITY_EVENT_VIEWER=true
VITE_ENABLE_LOG_VIEWER=true
VITE_DEFAULT_USAGE_BUCKET=minute
VITE_DASHBOARD_REFRESH_SECONDS=15
VITE_REQUEST_TIMEOUT_MS=15000

# Edge runtime paths.
CORE_URL=http://core:8080
EDGE_CONFIG_DIR=./edge/config
EDGE_CONFIG_PATH=/var/lib/cdnlite/config.json
METRIC_PATH=/var/lib/cdnlite/metrics.ndjson
CDNLITE_CACHE_DEFAULT_TTL=60s

# PowerDNS is disabled by default in local dev.
POWERDNS_ENABLED=0
POWERDNS_STRICT=0
POWERDNS_API_URL=http://powerdns:8081
POWERDNS_API_KEY=change-me
POWERDNS_SERVER_ID=localhost
POWERDNS_ZONE_KIND=NATIVE
POWERDNS_ZONE_NAMESERVERS=ns1.vaheed.net,ns2.vaheed.net
POWERDNS_PUBLIC_API_URL=http://localhost:8089
POWERDNS_HOST_PORT=8089
PDNS_PORT=8081

# Platform edge DNS defaults.
CDNLITE_EDGE_BASE_DOMAIN=vaheed.net
CDNLITE_EDGE_ZONE_PREFIX=edge
CDNLITE_EDGE_DEFAULT_TARGET=geo
CDNLITE_EDGE_TTL=60
CDNLITE_EDGE_HEALTH_MODE=ifportup
CDNLITE_EDGE_HEALTH_PORT=80
CDNLITE_EDGE_HEALTH_URL=/cdn-health
CDNLITE_EDGE_HEALTH_TIMEOUT=1
CDNLITE_EDGE_HEALTH_INTERVAL=10
CDNLITE_EDGE_HEALTH_MIN_FAILURES=2
CDNLITE_EDGE_SELECTOR=pickclosest
CDNLITE_EDGE_BACKUP_SELECTOR=empty
CDNLITE_EDGE_APEX_MODE=ALIAS
CDNLITE_GEO_DEFAULT_POLICY=auto
CDNLITE_GEO_ENABLE_COUNTRY_RULES=true
CDNLITE_GEO_ENABLE_CONTINENT_RULES=true
CDNLITE_GEO_ENABLE_REGION_RULES=true
CDNLITE_NS1_IP=
CDNLITE_NS2_IP=
CDNLITE_BOOTSTRAP_EDGE_DNS=1

# CI/test-only convenience.
EDGE_AGENT_IDLE=0
