#!/usr/bin/env php
<?php

use Illuminate\Foundation\Application;
use Symfony\Component\Console\Input\ArgvInput;

$command = $argv[1] ?? null;
$laravelCdnCommands = [
    'cdn:dns:reconcile',
    'cdn:powerdns:doctor',
    'cdn:powerdns:dry-run',
    'cdn:powerdns:force-sync',
    'cdn:edge:list',
    'cdn:edge:register-token',
    'cdn:edge:rotate-token',
    'cdn:edge:show',
    'cdn:edge:sync-config',
    'cdn:usage:ingest',
    'cdn:usage:summary',
    'cdn:usage:recalculate',
    'cdn:usage:prune',
    'cdn:recommendations:generate',
    'cdn:ssl:renew-due',
];
if (is_string($command) && str_starts_with($command, 'cdn:') && !in_array($command, $laravelCdnCommands, true)) {
    require __DIR__ . '/artisan-legacy';
    return;
}

define('LARAVEL_START', microtime(true));

// Register the Composer autoloader...
$autoload = __DIR__.'/vendor/autoload.php';
if (!is_file($autoload)) {
    fwrite(STDERR, "Laravel dependencies are not installed. Run composer install in core/ or rebuild the core container.\n");
    exit(1);
}

require $autoload;

// Bootstrap Laravel and handle the command...
/** @var Application $app */
$app = require_once __DIR__.'/bootstrap/app.php';

$status = $app->handleCommand(new ArgvInput);

exit($status);
