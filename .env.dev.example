# CDNLite local development environment template.
# Copy to .env before running root Docker Compose.

GITHUB_REPOSITORY_OWNER=local

POSTGRES_DB=cdnlite
POSTGRES_USER=cdnlite
POSTGRES_PASSWORD=cdnlite
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=cdnlite
DB_USERNAME=cdnlite
DB_PASSWORD=cdnlite

APP_ENV=local
APP_LOG_ENABLED=1
APP_LOG_LEVEL=info
APP_DEBUG=0
CDNLITE_API_TOKEN=
CDNLITE_SSL_SECRET_KEY=change-me-long-random-secret
CDNLITE_ORIGIN_SHIELD_SECRET=change-me-long-random-secret
CDNLITE_ACME_DIRECTORY_URL=https://acme-staging-v02.api.letsencrypt.org/directory
CDNLITE_ACME_CONTACT_EMAIL=admin@example.com
CDNLITE_ACME_DNS_PROPAGATION_SECONDS=0
CDNLITE_ACME_PUBLIC_DNS_PRECHECK=false
CDNLITE_ACME_DNS_VERIFY_ATTEMPTS=30
CDNLITE_ACME_DNS_VERIFY_INTERVAL_SECONDS=2
CDNLITE_ACME_POLL_ATTEMPTS=10
CDNLITE_SSL_JOB_STALE_RETRY_SECONDS=900
CDNLITE_SSL_SCHEDULER_INTERVAL_SECONDS=30
CDNLITE_SCHEDULER_IDLE=0
CDNLITE_NAMESERVER_CHECK_INTERVAL_SECONDS=86400
CDNLITE_SYNC_INTERVAL_SECONDS=30
CDNLITE_RETENTION_PRUNE_ENABLED=false
CDNLITE_RETENTION_INTERVAL_SECONDS=86400
CDNLITE_RETENTION_BATCH_SIZE=5000
CDNLITE_ANALYTICS_RETENTION_DAYS=30
CDNLITE_SECURITY_EVENT_RETENTION_DAYS=90
CDNLITE_DNS_EVENT_RETENTION_DAYS=30
CDNLITE_SSL_JOB_RETENTION_DAYS=180
CDNLITE_INGEST_KEY_RETENTION_DAYS=7

CDNLITE_ADMIN_SESSION_TTL_SECONDS=28800
CDNLITE_CORS_ALLOWED_ORIGINS=http://localhost:8082,http://127.0.0.1:8082
CDNLITE_DEV_ADMIN_USERNAME=admin@example.test
CDNLITE_DEV_ADMIN_PASSWORD=cdnlite-local-admin

EDGE_ID=edge-local-1
EDGE_TOKEN=edge-dev-token
DEV_MODE=0
CDNLITE_BOOTSTRAP_EDGE_TOKEN=1
CDNLITE_BOOTSTRAP_EDGE_ID=
CDNLITE_BOOTSTRAP_EDGE_TOKEN_VALUE=
EDGE_HOSTNAME=edge-local-1
EDGE_PUBLIC_IP=auto
EDGE_REGION=local
EDGE_VERSION=v1

CORE_HOST_PORT=8080
EDGE_HOST_PORT=8081
EDGE_TLS_HOST_PORT=8443
POSTGRES_HOST_PORT=5432
DASHBOARD_PORT=8082

VITE_CDNLITE_CORE_URL=http://localhost:8080
VITE_CDNLITE_EDGE_URL=http://localhost:8081
VITE_CDNLITE_APP_NAME=CDNLite Admin
VITE_CDNLITE_API_TOKEN=
VITE_ENABLE_EDGE_DEV_TOOLS=false
VITE_ENABLE_USAGE_SIMULATOR=false
VITE_ENABLE_SSL_TOOLS=true
VITE_ENABLE_SECURITY_EVENT_VIEWER=true
VITE_ENABLE_LOG_VIEWER=true
VITE_DEFAULT_USAGE_BUCKET=minute
VITE_DASHBOARD_REFRESH_SECONDS=15
VITE_REQUEST_TIMEOUT_MS=15000

CORE_URL=http://core:8080
EDGE_CONFIG_DIR=./edge/config
EDGE_CONFIG_PATH=/var/lib/cdnlite/config.json
EDGE_CONFIG_CACHE_PATH=/var/lib/cdnlite/config.json
EDGE_SYNC_STATUS_PATH=/var/lib/cdnlite/edge-sync-status.json
EDGE_CONFIG_MAX_STALE_SECONDS=0
METRIC_PATH=/var/lib/cdnlite/metrics.ndjson
SECURITY_EVENT_PATH=/var/lib/cdnlite/security-events.ndjson
CDNLITE_EDGE_MMDB_FILE=/var/lib/cdnlite/mmdb/GeoLite2-City.mmdb
CDNLITE_CACHE_DEFAULT_TTL=60s

# Edge hot-path and telemetry tuning - development sample.
CDNLITE_EDGE_WORKER_PROCESSES=1
CDNLITE_EDGE_WORKER_CONNECTIONS=1024
CDNLITE_EDGE_LIMITS_DICT_SIZE=10m
CDNLITE_EDGE_REQUEST_CONTEXT_DICT_SIZE=5m
CDNLITE_EDGE_METRIC_QUEUE_DICT_SIZE=5m
CDNLITE_EDGE_SECURITY_EVENT_QUEUE_DICT_SIZE=5m
CDNLITE_EDGE_CONFIG_MAX_BYTES=1048576
CDNLITE_EDGE_CONFIG_REFRESH_SECONDS=1
CDNLITE_EDGE_TELEMETRY_BATCH_SIZE=50
CDNLITE_EDGE_TELEMETRY_FLUSH_INTERVAL_SECONDS=1
CDNLITE_EDGE_TELEMETRY_QUEUE_MAX_ITEMS=5000
CDNLITE_EDGE_TELEMETRY_QUEUE_MAX_BYTES=524288
CDNLITE_EDGE_RESOLVER=127.0.0.11
CDNLITE_EDGE_CLIENT_HEADER_BUFFER_SIZE=4k
CDNLITE_EDGE_LARGE_CLIENT_HEADER_BUFFERS=4 8k
CDNLITE_EDGE_CLIENT_BODY_BUFFER_SIZE=64k
CDNLITE_EDGE_CLIENT_MAX_BODY_SIZE=10m
CDNLITE_EDGE_PROXY_CONNECT_TIMEOUT=3s
CDNLITE_EDGE_PROXY_READ_TIMEOUT=30s
CDNLITE_EDGE_PROXY_SEND_TIMEOUT=30s

# Bundled DNSGeo/PowerDNS runtime. Operational API settings are also saved
# through the Settings dashboard/API.
CDNLITE_POWERDNS_VERIFY_AFTER_WRITE=true
CDNLITE_POWERDNS_RETRIES=3
CDNLITE_POWERDNS_RETRY_SLEEP_MS=250
CDNLITE_POWERDNS_TIMEOUT_SECONDS=10
CDNLITE_DNS_BASE_DOMAIN=example.net
CDNLITE_CDN_ZONE=cdn.example.net
PDNS_DB_PASSWORD=cdnlite-pdns-db
PDNS_POSTGRES_SUPERUSER_PASSWORD=cdnlite-pdns-postgres
PDNS_REPLICATION_PASSWORD=cdnlite-pdns-replication
PDNS_WEBSERVER_PASSWORD=cdnlite-local-web-password
PDNS_API_KEY=cdnlite-local-powerdns-key
PDNS_API_HOST_PORT=8089
PDNS_DNS_HOST_PORT=5353
PDNS_ALLOW_AXFR_IPS=127.0.0.1,::1,172.30.0.0/16
PDNS_ALSO_NOTIFY=
PDNS_PG_MAX_WAL_SENDERS=10
PDNS_PG_MAX_REPLICATION_SLOTS=10
PDNS_PG_WAL_KEEP_SIZE=512MB
PDNS_PG_TLS_DAYS=3650
PDNS_PG_TLS_SAN=DNS:pdns-postgres,IP:127.0.0.1
POWERDNS_PUBLIC_API_URL=http://localhost:8089
POWERADMIN_HOST_PORT=8084
POWERADMIN_DB_PASSWORD=cdnlite-poweradmin-db
POWERADMIN_ADMIN_USERNAME=admin
POWERADMIN_ADMIN_PASSWORD=admin
POWERADMIN_SESSION_KEY=cdnlite-local-session-key-change-me
CDNLITE_MMDB_PROVIDER=dbip-jsdelivr

CDNLITE_EDGE_BASE_DOMAIN=vaheed.net
CDNLITE_EDGE_ZONE_PREFIX=edge
CDNLITE_EDGE_DEFAULT_TARGET=geo
CDNLITE_EDGE_TTL=60
CDNLITE_EDGE_HEALTH_MODE=ifportup
CDNLITE_EDGE_HEALTH_PORT=80
CDNLITE_EDGE_HEALTH_URL=/cdn-health
CDNLITE_EDGE_HEALTH_TIMEOUT=1
CDNLITE_EDGE_HEALTH_INTERVAL=10
CDNLITE_EDGE_HEALTH_MIN_FAILURES=2
CDNLITE_EDGE_SELECTOR=pickclosest
CDNLITE_EDGE_BACKUP_SELECTOR=empty
CDNLITE_GEO_DEFAULT_POLICY=auto
CDNLITE_GEO_ENABLE_COUNTRY_RULES=true
CDNLITE_GEO_ENABLE_CONTINENT_RULES=true
CDNLITE_GEO_ENABLE_REGION_RULES=true
CDNLITE_NS1_IP=
CDNLITE_NS2_IP=
CDNLITE_BOOTSTRAP_EDGE_DNS=1
CDNLITE_READINESS_SNAPSHOT_MAX_AGE_SECONDS=900

EDGE_AGENT_IDLE=0
