# CDNLite production environment template.
# Copy to .env on the production host and replace every CHANGE_ME value.

GITHUB_REPOSITORY_OWNER=CHANGE_ME_REGISTRY_OWNER

# PostgreSQL. Prefer a private managed database or a private Compose network.
POSTGRES_DB=cdnlite
POSTGRES_USER=cdnlite
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_DATABASE_PASSWORD
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=cdnlite
DB_USERNAME=cdnlite
DB_PASSWORD=CHANGE_ME_LONG_RANDOM_DATABASE_PASSWORD

# Core runtime.
APP_ENV=production
APP_LOG_ENABLED=1
APP_LOG_LEVEL=info
APP_DEBUG=0
CDNLITE_API_TOKEN=CHANGE_ME_LONG_RANDOM_CONTROL_PLANE_TOKEN
CDNLITE_SSL_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SSL_SECRET_KEY
CDNLITE_ORIGIN_SHIELD_SECRET=CHANGE_ME_LONG_RANDOM_ORIGIN_SHIELD_SECRET
CDNLITE_ACME_DIRECTORY_URL=https://acme-v02.api.letsencrypt.org/directory
CDNLITE_ACME_CONTACT_EMAIL=admin@example.com
CDNLITE_ACME_DNS_PROPAGATION_SECONDS=30
CDNLITE_ACME_POLL_ATTEMPTS=30

# Dashboard admin.
# Do not use the local admin/admin bootstrap in production.
CDNLITE_ADMIN_SESSION_TTL_SECONDS=28800
CDNLITE_CORS_ALLOWED_ORIGINS=https://dashboard.cdn.example.com
CDNLITE_BOOTSTRAP_ADMIN_USER=0
CDNLITE_BOOTSTRAP_ADMIN_USERNAME=
CDNLITE_BOOTSTRAP_ADMIN_PASSWORD=
CDNLITE_BOOTSTRAP_ADMIN_DISPLAY_NAME=

# Edge identity. Provision and rotate edge tokens with the CLI.
EDGE_ID=edge-prod-1
EDGE_TOKEN=CHANGE_ME_LONG_RANDOM_EDGE_TOKEN
DEV_MODE=0
CDNLITE_BOOTSTRAP_EDGE_TOKEN=0
CDNLITE_BOOTSTRAP_EDGE_ID=
CDNLITE_BOOTSTRAP_EDGE_TOKEN_VALUE=
EDGE_HOSTNAME=edge-prod-1.example.com
EDGE_PUBLIC_IP=auto
EDGE_REGION=us-east-1
EDGE_VERSION=v1

# Host ports. Bind API/dashboard behind your reverse proxy or private ingress.
CORE_HOST_PORT=8080
EDGE_HOST_PORT=80
EDGE_TLS_HOST_PORT=443
POSTGRES_HOST_PORT=5432
DASHBOARD_PORT=8082

# Dashboard build values. Browser users must be able to resolve these URLs.
VITE_CDNLITE_CORE_URL=https://api.cdn.example.com
VITE_CDNLITE_EDGE_URL=https://edge.cdn.example.com
VITE_CDNLITE_APP_NAME=CDNLite Admin
VITE_CDNLITE_API_TOKEN=
VITE_ENABLE_EDGE_DEV_TOOLS=false
VITE_ENABLE_USAGE_SIMULATOR=false
VITE_ENABLE_SSL_TOOLS=true
VITE_ENABLE_SECURITY_EVENT_VIEWER=true
VITE_ENABLE_LOG_VIEWER=true
VITE_DEFAULT_USAGE_BUCKET=minute
VITE_DASHBOARD_REFRESH_SECONDS=15
VITE_REQUEST_TIMEOUT_MS=15000

# Edge runtime paths.
CORE_URL=https://api.cdn.example.com
EDGE_CONFIG_DIR=/var/lib/cdnlite/edge
EDGE_CONFIG_PATH=/var/lib/cdnlite/config.json
EDGE_CONFIG_CACHE_PATH=/var/lib/cdnlite/config.json
EDGE_SYNC_STATUS_PATH=/var/lib/cdnlite/edge-sync-status.json
EDGE_CONFIG_MAX_STALE_SECONDS=900
METRIC_PATH=/var/lib/cdnlite/metrics.ndjson
SECURITY_EVENT_PATH=/var/lib/cdnlite/security-events.ndjson
CDNLITE_CACHE_DEFAULT_TTL=60s

# Bundled DNSGeo/PowerDNS. Replace every secret before deployment.
CDNLITE_POWERDNS_VERIFY_AFTER_WRITE=true
CDNLITE_POWERDNS_RETRIES=3
CDNLITE_POWERDNS_RETRY_SLEEP_MS=250
CDNLITE_POWERDNS_TIMEOUT_SECONDS=10
CDNLITE_DNS_BASE_DOMAIN=cdn.example.com
CDNLITE_CDN_ZONE=cdn.cdn.example.com
PDNS_DB_PASSWORD=CHANGE_ME_PDNS_DB_PASSWORD
PDNS_POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_PDNS_POSTGRES_PASSWORD
PDNS_REPLICATION_PASSWORD=CHANGE_ME_PDNS_REPLICATION_PASSWORD
PDNS_WEBSERVER_PASSWORD=CHANGE_ME_PDNS_WEBSERVER_PASSWORD
PDNS_API_KEY=CHANGE_ME_POWERDNS_API_KEY
PDNS_API_HOST_PORT=8089
PDNS_DNS_HOST_PORT=53
POWERADMIN_HOST_PORT=8084
POWERADMIN_DB_PASSWORD=CHANGE_ME_POWERADMIN_DB_PASSWORD
POWERADMIN_ADMIN_USERNAME=admin
POWERADMIN_ADMIN_PASSWORD=CHANGE_ME_POWERADMIN_PASSWORD
POWERADMIN_SESSION_KEY=CHANGE_ME_64_CHAR_SESSION_KEY
CDNLITE_MMDB_PROVIDER=dbip-jsdelivr

# Platform edge DNS.
CDNLITE_EDGE_BASE_DOMAIN=cdn.example.com
CDNLITE_EDGE_ZONE_PREFIX=edge
CDNLITE_EDGE_DEFAULT_TARGET=geo
CDNLITE_EDGE_TTL=60
CDNLITE_EDGE_HEALTH_MODE=ifportup
CDNLITE_EDGE_HEALTH_PORT=80
CDNLITE_EDGE_HEALTH_URL=/cdn-health
CDNLITE_EDGE_HEALTH_TIMEOUT=1
CDNLITE_EDGE_HEALTH_INTERVAL=10
CDNLITE_EDGE_HEALTH_MIN_FAILURES=2
CDNLITE_EDGE_SELECTOR=pickclosest
CDNLITE_EDGE_BACKUP_SELECTOR=empty
CDNLITE_EDGE_APEX_MODE=ALIAS
CDNLITE_GEO_DEFAULT_POLICY=auto
CDNLITE_GEO_ENABLE_COUNTRY_RULES=true
CDNLITE_GEO_ENABLE_CONTINENT_RULES=true
CDNLITE_GEO_ENABLE_REGION_RULES=true
CDNLITE_NS1_IP=
CDNLITE_NS2_IP=
CDNLITE_BOOTSTRAP_EDGE_DNS=1
CDNLITE_READINESS_SNAPSHOT_MAX_AGE_SECONDS=900

EDGE_AGENT_IDLE=0
