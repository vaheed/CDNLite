# ============================================================
# CDNLite - PowerDNS Primary
# Role: Authoritative primary DNS server for CDNLite zones
# Fill every CHANGE_ME value before running docker compose up -d
# ============================================================

PDNS_API_KEY=CHANGE_ME_LONG_RANDOM_PDNS_API_KEY
PDNS_REPLICA_IP=CHANGE_ME_REPLICA_SERVER_IP
PDNS_DNS_PORT=53
PDNS_API_PORT=8081
