# ============================================================
# CDNLite - Starter
# Role: Full stack on one machine for quick evaluation or a small VPS
# Fill every CHANGE_ME value before running docker compose up -d
# ============================================================

REGISTRY_OWNER=CHANGE_ME_GHCR_OWNER
GITHUB_REPOSITORY_OWNER=CHANGE_ME_GHCR_OWNER
IMAGE_TAG=CHANGE_ME_RELEASE_TAG

POSTGRES_DB=cdnlite
POSTGRES_USER=cdnlite
POSTGRES_PASSWORD=CHANGE_ME_LONG_RANDOM_DB_PASSWORD
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=cdnlite
DB_USERNAME=cdnlite
DB_PASSWORD=CHANGE_ME_LONG_RANDOM_DB_PASSWORD

APP_ENV=production
APP_LOG_ENABLED=1
APP_LOG_LEVEL=info
APP_DEBUG=0
CDNLITE_API_TOKEN=CHANGE_ME_LONG_RANDOM_API_TOKEN
CDNLITE_SSL_SECRET_KEY=CHANGE_ME_LONG_RANDOM_SSL_KEY
CDNLITE_ORIGIN_SHIELD_SECRET=CHANGE_ME_LONG_RANDOM_SHIELD_SECRET
CDNLITE_ACME_DIRECTORY_URL=https://acme-v02.api.letsencrypt.org/directory
CDNLITE_ACME_CONTACT_EMAIL=admin@CHANGE_ME_DOMAIN
CDNLITE_ACME_DNS_PROPAGATION_SECONDS=30
CDNLITE_ACME_POLL_ATTEMPTS=30

# Starter-only convenience - disable after first login.
CDNLITE_ADMIN_SESSION_TTL_SECONDS=28800
CDNLITE_CORS_ALLOWED_ORIGINS=http://CHANGE_ME_SERVER_IP:8082
CDNLITE_BOOTSTRAP_ADMIN_USER=1
CDNLITE_BOOTSTRAP_ADMIN_USERNAME=admin
CDNLITE_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
CDNLITE_BOOTSTRAP_ADMIN_DISPLAY_NAME=Starter Admin

CDNLITE_BOOTSTRAP_EDGE_TOKEN=1
CDNLITE_BOOTSTRAP_EDGE_ID=
CDNLITE_BOOTSTRAP_EDGE_TOKEN_VALUE=
EDGE_ID=edge-starter-1
EDGE_TOKEN=CHANGE_ME_LONG_RANDOM_EDGE_TOKEN
DEV_MODE=0
EDGE_HOSTNAME=edge-starter-1.CHANGE_ME_DOMAIN
EDGE_PUBLIC_IP=auto
EDGE_REGION=starter
EDGE_VERSION=v1

CORE_HOST_PORT=8080
EDGE_HOST_PORT=80
EDGE_TLS_HOST_PORT=443
DASHBOARD_PORT=8082

VITE_CDNLITE_CORE_URL=http://CHANGE_ME_SERVER_IP:8080
VITE_CDNLITE_EDGE_URL=http://CHANGE_ME_SERVER_IP:80
VITE_CDNLITE_APP_NAME=CDNLite Admin
VITE_CDNLITE_API_TOKEN=
VITE_ENABLE_EDGE_DEV_TOOLS=false
VITE_ENABLE_USAGE_SIMULATOR=false
VITE_ENABLE_SSL_TOOLS=true
VITE_ENABLE_SECURITY_EVENT_VIEWER=true
VITE_ENABLE_LOG_VIEWER=true
VITE_DEFAULT_USAGE_BUCKET=minute
VITE_DASHBOARD_REFRESH_SECONDS=15
VITE_REQUEST_TIMEOUT_MS=15000

CORE_URL=http://core:8080
EDGE_CONFIG_PATH=/var/lib/cdnlite/config.json
EDGE_CONFIG_CACHE_PATH=/var/lib/cdnlite/config.json
EDGE_SYNC_STATUS_PATH=/var/lib/cdnlite/edge-sync-status.json
EDGE_CONFIG_MAX_STALE_SECONDS=900
METRIC_PATH=/var/lib/cdnlite/metrics.ndjson
SECURITY_EVENT_PATH=/var/lib/cdnlite/security-events.ndjson
CDNLITE_CACHE_DEFAULT_TTL=60s

PDNS_API_KEY=CHANGE_ME_LONG_RANDOM_PDNS_API_KEY
PDNS_DNS_PORT=53
PDNS_API_PORT=8081

CDNLITE_EDGE_BASE_DOMAIN=CHANGE_ME_DOMAIN
CDNLITE_CDN_ZONE=cdn.CHANGE_ME_DOMAIN
CDNLITE_CDN_PROXY_HOST=proxy.cdn.CHANGE_ME_DOMAIN
CDNLITE_EDGE_ZONE_PREFIX=edge
CDNLITE_EDGE_DEFAULT_TARGET=geo
CDNLITE_EDGE_TTL=60
CDNLITE_EDGE_HEALTH_MODE=ifportup
CDNLITE_EDGE_HEALTH_PORT=80
CDNLITE_EDGE_HEALTH_URL=/cdn-health
CDNLITE_EDGE_HEALTH_TIMEOUT=1
CDNLITE_EDGE_HEALTH_INTERVAL=10
CDNLITE_EDGE_HEALTH_MIN_FAILURES=2
CDNLITE_EDGE_SELECTOR=pickclosest
CDNLITE_EDGE_BACKUP_SELECTOR=empty
CDNLITE_EDGE_APEX_MODE=ALIAS
CDNLITE_GEO_DEFAULT_POLICY=auto
CDNLITE_GEO_ENABLE_COUNTRY_RULES=true
CDNLITE_GEO_ENABLE_CONTINENT_RULES=true
CDNLITE_GEO_ENABLE_REGION_RULES=true
CDNLITE_NS1_IP=CHANGE_ME_NS1_IP
CDNLITE_NS2_IP=CHANGE_ME_NS2_IP
CDNLITE_BOOTSTRAP_EDGE_DNS=1
CDNLITE_READINESS_SNAPSHOT_MAX_AGE_SECONDS=900

CDNLITE_SCHEDULER_IDLE=0
EDGE_AGENT_IDLE=0
