# ============================================================
# CDNLite - Edge POP
# Role: OpenResty proxy and agent for one Point of Presence
# Fill every CHANGE_ME value before running docker compose up -d
# ============================================================

REGISTRY_OWNER=CHANGE_ME_GHCR_OWNER
IMAGE_TAG=CHANGE_ME_RELEASE_TAG

# POP identity. Set these uniquely per server.
EDGE_ID=CHANGE_ME_POP_ID
EDGE_TOKEN=CHANGE_ME_LONG_RANDOM_EDGE_TOKEN
EDGE_HOSTNAME=CHANGE_ME_POP_HOSTNAME
EDGE_REGION=CHANGE_ME_REGION
EDGE_COUNTRY=
EDGE_CONTINENT=
EDGE_PUBLIC_IP=auto

# Core connection.
CORE_URL=https://api.CHANGE_ME_DOMAIN

# Ports. Bind on 80/443 in production.
EDGE_HOST_PORT=80
EDGE_TLS_HOST_PORT=443

# Runtime tuning.
DEV_MODE=0
CDNLITE_CACHE_DEFAULT_TTL=60s
EDGE_CONFIG_MAX_STALE_SECONDS=900
EDGE_VERSION=v1
EDGE_CONFIG_PATH=/var/lib/cdnlite/config.json
EDGE_CONFIG_CACHE_PATH=/var/lib/cdnlite/config.json
EDGE_SYNC_STATUS_PATH=/var/lib/cdnlite/edge-sync-status.json
METRIC_PATH=/var/lib/cdnlite/metrics.ndjson
SECURITY_EVENT_PATH=/var/lib/cdnlite/security-events.ndjson
CDNLITE_EDGE_MMDB_FILE=/var/lib/cdnlite/mmdb/GeoLite2-City.mmdb

# Edge hot-path and telemetry tuning - production POP starting point.
CDNLITE_EDGE_WORKER_PROCESSES=auto
CDNLITE_EDGE_WORKER_CONNECTIONS=8192
CDNLITE_EDGE_LIMITS_DICT_SIZE=50m
CDNLITE_EDGE_REQUEST_CONTEXT_DICT_SIZE=20m
CDNLITE_EDGE_METRIC_QUEUE_DICT_SIZE=32m
CDNLITE_EDGE_SECURITY_EVENT_QUEUE_DICT_SIZE=32m
CDNLITE_EDGE_CONFIG_MAX_BYTES=5242880
CDNLITE_EDGE_CONFIG_REFRESH_SECONDS=1
CDNLITE_EDGE_TELEMETRY_BATCH_SIZE=500
CDNLITE_EDGE_TELEMETRY_FLUSH_INTERVAL_SECONDS=1
CDNLITE_EDGE_TELEMETRY_QUEUE_MAX_ITEMS=100000
CDNLITE_EDGE_TELEMETRY_QUEUE_MAX_BYTES=16777216
CDNLITE_EDGE_RESOLVER=127.0.0.11
CDNLITE_EDGE_CLIENT_HEADER_BUFFER_SIZE=8k
CDNLITE_EDGE_LARGE_CLIENT_HEADER_BUFFERS=8 16k
CDNLITE_EDGE_CLIENT_BODY_BUFFER_SIZE=256k
CDNLITE_EDGE_CLIENT_MAX_BODY_SIZE=100m
CDNLITE_EDGE_PROXY_CONNECT_TIMEOUT=5s
CDNLITE_EDGE_PROXY_READ_TIMEOUT=60s
CDNLITE_EDGE_PROXY_SEND_TIMEOUT=60s

EDGE_AGENT_IDLE=0
