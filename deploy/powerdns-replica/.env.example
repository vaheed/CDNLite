# ============================================================
# CDNLite - PowerDNS Replica
# Role: Authoritative secondary DNS server that pulls zones over AXFR
# Fill every CHANGE_ME value before running docker compose up -d
# ============================================================

PDNS_PRIMARY_IP=CHANGE_ME_PRIMARY_POWERDNS_IP
PDNS_PRIMARY_ACCOUNT=cdnlite
PDNS_DNS_PORT=53
