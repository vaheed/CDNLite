# CDNLite DNSGeo production bundle.
# Replace every CHANGE_ME value before deployment.

PDNS_POSTGRES_SUPERUSER_PASSWORD=CHANGE_ME_LONG_RANDOM_POSTGRES_PASSWORD
PDNS_DB_PASSWORD=CHANGE_ME_LONG_RANDOM_PDNS_DB_PASSWORD
POWERADMIN_DB_PASSWORD=CHANGE_ME_LONG_RANDOM_POWERADMIN_DB_PASSWORD
PDNS_REPLICATION_PASSWORD=CHANGE_ME_LONG_RANDOM_REPLICATION_PASSWORD
PDNS_API_KEY=CHANGE_ME_LONG_RANDOM_PDNS_API_KEY
PDNS_WEBSERVER_PASSWORD=CHANGE_ME_LONG_RANDOM_WEBSERVER_PASSWORD
POWERADMIN_ADMIN_PASSWORD=CHANGE_ME_LONG_RANDOM_POWERADMIN_PASSWORD
POWERADMIN_SESSION_KEY=CHANGE_ME_LONG_RANDOM_SESSION_KEY

PDNS_PG_MAX_WAL_SENDERS=10
PDNS_PG_MAX_REPLICATION_SLOTS=10
PDNS_PG_WAL_KEEP_SIZE=512MB
PDNS_PG_TLS_DAYS=365

CDNLITE_DNS_BASE_DOMAIN=CHANGE_ME_DOMAIN
CDNLITE_CDN_ZONE=cdn.CHANGE_ME_DOMAIN
CDNLITE_DNS_NS1=ns1.CHANGE_ME_DOMAIN
CDNLITE_DNS_NS2=ns2.CHANGE_ME_DOMAIN
CDNLITE_DNS_HOSTMASTER=hostmaster.CHANGE_ME_DOMAIN

CDNLITE_MMDB_PROVIDER=dbip-jsdelivr
CDNLITE_MMDB_DOWNLOAD_URL=
CDNLITE_MMDB_DOWNLOAD_INTERVAL_SECONDS=86400
CDNLITE_MMDB_DOWNLOAD_RETRIES=5
CDNLITE_MMDB_EXPECTED_SHA256=

PDNS_DNS_BIND_ADDRESS=0.0.0.0
PDNS_DNS_PORT=53
PDNS_API_BIND_ADDRESS=127.0.0.1
PDNS_API_PORT=8089
PDNS_WEBSERVER_ALLOW_FROM=127.0.0.1,172.31.0.0/24,CHANGE_ME_CORE_IP

POWERADMIN_BIND_ADDRESS=127.0.0.1
POWERADMIN_PORT=8084
POWERADMIN_TAG=stable
POWERADMIN_ADMIN_USERNAME=admin
POWERADMIN_ADMIN_EMAIL=admin@CHANGE_ME_DOMAIN
